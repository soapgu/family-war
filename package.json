{
  "name": "family-war",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev --prefix server\" \"npm run start --prefix client\"",
    "server": "npm run dev --prefix server",
    "client": "npm run start --prefix client",
    "test": "npm test --prefix server -- --verbose --no-cache",
    "test:integration": "npm run test:integration --prefix server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
